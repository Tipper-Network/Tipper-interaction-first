{
  "name": "@tipper/api",
  "version": "0.0.1",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "pnpm run prisma:generate && nest build",
    "start": "node dist/main",
    "dev": "nest start --watch",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:generate": "prisma generate --schema ./schema/prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema ./schema/prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema ./schema/prisma/schema.prisma",
    "prisma:migrate:create": "prisma migrate dev --create-only --schema ./schema/prisma/schema.prisma",
    "prisma:migrate:reset": "prisma migrate reset --schema ./schema/prisma/schema.prisma --force",
    "prisma:db:push": "prisma db push --schema ./schema/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema ./schema/prisma/schema.prisma",
    "zenstack:generate": "npx zenstack generate --schema ./schema/schema.zmodel --no-compile && pnpm run prisma:generate",
    "seed:personas": "ts-node -r tsconfig-paths/register scripts/seed-personas.ts",
    "seed:values": "ts-node -r tsconfig-paths/register scripts/seed-values.ts",
    "seed:interests": "ts-node -r tsconfig-paths/register scripts/seed-interests.ts",
    "seed:entity_archetypes": "ts-node -r tsconfig-paths/register scripts/seed-entity_archetypes.ts",
    "seed:entity_values": "ts-node -r tsconfig-paths/register scripts/seed-entity_values.ts",
    "seed:entity_interests": "ts-node -r tsconfig-paths/register scripts/seed-entity_interests.ts",
    "seed:vibes": "ts-node -r tsconfig-paths/register scripts/seed-vibes.ts",
    "seed:tags": "ts-node -r tsconfig-paths/register scripts/seed-tags.ts",
    "seed:business_types": "ts-node -r tsconfig-paths/register scripts/seed-business_types.ts",
    "seed": "pnpm run seed:tags && pnpm run seed:values && pnpm run seed:personas && pnpm run seed:interests && pnpm run seed:entity_archetypes && pnpm run seed:entity_values && pnpm run seed:entity_interests && pnpm run seed:vibes"
  
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "prisma": {
    "schema": "./schema/prisma/schema.prisma"
  },
  "dependencies": {
    "@tipper/shared": "workspace:*",
    "@aws-sdk/client-s3": "^3.901.0",
    "@aws-sdk/s3-request-presigner": "^3.901.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mapped-types": "*",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.6",
    "@nestjs/schedule": "^6.0.0",
    "@nestjs/websockets": "^11.1.6",
    "@prisma/client": "^6.19.2",
    "@zenstackhq/runtime": "3.0.0-alpha.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cookie": "^1.0.2",
    "cookie-parser": "^1.4.7",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.1",
    "jsonwebtoken": "^9.0.2",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.0.3",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.7",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "install": "^0.13.0",
    "jest": "^30.0.0",
    "npm": "^11.6.0",
    "prettier": "^3.6.2",
    "prisma": "^6.16.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": ["**/*.(t|j)s"],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
