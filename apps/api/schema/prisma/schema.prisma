model EntityCommunity {
  id                         String                    @id() @default(uuid())
  community_name             String
  community_level            Int                       @default(1)
  entity_id                  String                    @unique()
  entity                     Entity                    @relation("EntityCommunity", fields: [entity_id], references: [id], onDelete: Cascade)
  initiated_by_profile_id    String?
  initiated_by               Profile?                  @relation("CommunityInitiator", fields: [initiated_by_profile_id], references: [id])
  slug                       String                    @unique()
  description                String?
  users_count                Int                       @default(0)
  community_status           EntityCommunityStatus     @default(PENDING_APPROVAL)
  entity_community_privacy   EntityCommunityPrivacy    @default(PUBLIC)
  feedback_tickets           FeedbackTicket[]
  thoughts                   Thought[]
  polls                      Poll[]
  community_qnas             CommunityQNA[]
  group_chat                 GroupChat[]
  request_claims             RequestClaim[]
  members                    EntityCommunityMember[]
  entity_community_positions EntityCommunityPosition[]
  visits                     UserCommunityVisit[]
  governance_stage           Int                       @default(1)
  isAutonomous               Boolean                   @default(false)
  governance_config          Json?
  min_level_to_customize     Int                       @default(3)

  @@index([entity_id, slug])
}

model Entity {
  id                               String                          @id() @default(uuid())
  name                             String
  slug                             String                          @unique()
  entity_type                      EntityType                      @default(BUSINESS)
  description                      String?
  phone                            String?
  email                            String?
  instagram_url                    String?
  owner_phone_number               String?
  owner_id                         String?
  owner                            User?                           @relation(fields: [owner_id], references: [id])
  longitude                        Float?
  latitude                         Float?
  accuracy                         Float?
  operates_online                  Boolean                         @default(false)
  metadata                         Json?
  address                          Json?
  schedule                         Json?
  entity_status                    EntityStatus                    @default(UNCLAIMED)
  entity_community                 EntityCommunity?                @relation("EntityCommunity")
  request_claims                   RequestClaim[]
  entity_interests                 EntityInterestsEntries[]
  entity_values                    EntityValuesEntries[]
  entity_archetypes                EntityArchetypesEntries[]
  entity_positions                 EntityPosition[]
  operational_affiliations         ProfileOperationalAffiliation[]
  commercial_affiliations          ProfileCommercialAffiliation[]
  strategic_affiliations           ProfileStrategicAffiliation[]
  sent_partnership_invitations     PartnershipInvitation[]         @relation("InviterEntityInvitations")
  received_partnership_invitations PartnershipInvitation[]         @relation("InviteeEntityInvitations")
  partnerships_as_a                Partnership[]                   @relation("PartnershipEntityA")
  partnerships_as_b                Partnership[]                   @relation("PartnershipEntityB")
  offerings                        Offering[]
  brand                            Brand?
  entity_media                     EntityMedia[]
  tags                             EntityTag[]
  posts                            Post[]
  enterprise_id                    String?
  enterprise                       Enterprise?                     @relation(fields: [enterprise_id], references: [id])

  @@index([slug, instagram_url, email, phone])
}

model EntityMedia {
  id         String          @id() @default(uuid())
  entity_id  String
  entity     Entity          @relation(fields: [entity_id], references: [id], onDelete: Cascade)
  key        String
  type       MediaType
  role       EntityMediaRole
  created_at DateTime        @default(now())
  updated_at DateTime        @updatedAt()

  @@index([entity_id])
}

model EntityInterestsEntries {
  id              String                   @id() @default(uuid())
  entity_id       String
  interest_id     String
  entity          Entity                   @relation(fields: [entity_id], references: [id], onDelete: Cascade)
  entity_interest ReferenceEntityInterests @relation(fields: [interest_id], references: [id], onDelete: Cascade)

  @@unique([entity_id, interest_id])
  @@index([entity_id])
  @@index([interest_id])
}

model EntityValuesEntries {
  id           String                @id() @default(uuid())
  entity_id    String
  value_id     String
  entity       Entity                @relation(fields: [entity_id], references: [id], onDelete: Cascade)
  entity_value ReferenceEntityValues @relation(fields: [value_id], references: [id], onDelete: Cascade)

  @@unique([entity_id, value_id])
  @@index([entity_id])
  @@index([value_id])
}

model EntityArchetypesEntries {
  id               String                    @id() @default(uuid())
  entity_id        String
  archetype_id     String
  entity           Entity                    @relation(fields: [entity_id], references: [id], onDelete: Cascade)
  entity_archetype ReferenceEntityArchetypes @relation(fields: [archetype_id], references: [id], onDelete: Cascade)

  @@unique([entity_id, archetype_id])
  @@index([entity_id])
  @@index([archetype_id])
}

model User {
  id                       String                   @id() @default(uuid())
  email                    String                   @unique()
  email_verified           Boolean                  @default(false)
  password                 String?
