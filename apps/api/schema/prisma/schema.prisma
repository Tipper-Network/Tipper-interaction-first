model FeedbackTicket {
  id                String                        @id() @default(uuid())
  title             String
  description       String
  community_id      String
  community         EntityCommunity               @relation(fields: [community_id], references: [id])
  author_profile_id String
  author            Profile                       @relation("FeedbackTicketAuthor", fields: [author_profile_id], references: [id])
  vote_box_id       String                        @unique()
  vote_box          VoteBox                       @relation(fields: [vote_box_id], references: [id])
  status            TicketStatus
  type              TicketType
  priority          Int?
  isArchived        Boolean                       @default(false)
  duplicateOf_id    String?
  duplicateOf       FeedbackTicket?               @relation("TicketDuplicates", fields: [duplicateOf_id], references: [id])
  duplicates        FeedbackTicket[]              @relation("TicketDuplicates")
  comments          FeedbackComment[]
  statusHistory     FeedbackTicketStatusHistory[]
  createdAt         DateTime                      @default(now())
  updatedAt         DateTime                      @updatedAt()
}

model FeedbackTicketStatusHistory {
  id                   String         @id() @default(uuid())
  ticket_id            String
  ticket               FeedbackTicket @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  oldStatus            TicketStatus?
  newStatus            TicketStatus
  changedBy_profile_id String
  changedBy            Profile        @relation("TicketStatusChanger", fields: [changedBy_profile_id], references: [id])
  note                 String?
  changedAt            DateTime       @default(now())

  @@index([ticket_id])
  @@index([changedBy_profile_id])
}

model FeedbackComment {
  id                String         @id() @default(uuid())
  content           String
  ticket_id         String
  ticket            FeedbackTicket @relation(fields: [ticket_id], references: [id])
  vote_box_id       String         @unique()
  vote_box          VoteBox        @relation(fields: [vote_box_id], references: [id])
  author_profile_id String
  author            Profile        @relation("FeedbackCommentAuthor", fields: [author_profile_id], references: [id])
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt()
}

model UserInviteToken {
  id         String       @id() @default(uuid())
  user_id    String       @unique()
  user       User         @relation(fields: [user_id], references: [id])
  token      String       @unique()
  invites    UserInvite[]
  created_at DateTime     @default(now())
  is_active  Boolean      @default(true)

  @@index([user_id])
}

model UserInvite {
  id                      String                 @id() @default(uuid())
  token_id                String
  token                   UserInviteToken        @relation(fields: [token_id], references: [id])
  /// userId thats invited to Tipper through the community or other things.
  invited_user_id         String?
  invited_user            User?                  @relation("InvitedUser", fields: [invited_user_id], references: [id])
  root_inviter_user_id    String
  root_inviter_user       User                   @relation("RootInviter", fields: [root_inviter_user_id], references: [id])
  status                  InviteStatus           @default(PENDING)
  scanned_at              DateTime?
  created_at              DateTime               @default(now())
  entity_community_invite EntityCommunityInvite?
  source                  UserInviteSource

  @@index([token_id])
  @@index([root_inviter_user_id])
}

model EntityCommunityInvite {
  id                    String                    @id() @default(uuid())
  invite_id             String                    @unique()
  invite                UserInvite                @relation(fields: [invite_id], references: [id])
  inviter_membership_id String
  inviter_membership    EntityCommunityMember     @relation(fields: [inviter_membership_id], references: [id])
  why_initiating        String
  relationship_context  String
  what_invitee_does     String?
  why_invitee_wants_in  String?
  vote_status           CommunityInviteVoteStatus @default(PENDING_VOTE)
  vote_threshold        Int                       @default(3)
  decided_at            DateTime?
  vote_box_id           String?                   @unique()
  vote_box              VoteBox?                  @relation(fields: [vote_box_id], references: [id])
  resulting_membership  EntityCommunityMember?    @relation("InviteOrigin")

  @@index([inviter_membership_id])
  @@index([vote_status])
}

model EntityCommunityMember {
  id                               String                          @id() @default(uuid())
  status                           EntityCommunityMembershipStatus @default(PENDING)
  visit_count                      Int                             @default(0)
  lastVisitedAt                    DateTime?
  joinedAt                         DateTime                        @default(now())
  member_level                     Int                             @default(1)
  entity_community_id              String
  entity_community                 EntityCommunity                 @relation(fields: [entity_community_id], references: [id], onDelete: Cascade)
  profile_id                       String
  profile                          Profile                         @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  entity_community_member_position EntityCommunityMemberPosition[]
  entity_community_invites         EntityCommunityInvite[]
  origin_invite_id                 String?                         @unique()
  origin_invite                    EntityCommunityInvite?          @relation("InviteOrigin", fields: [origin_invite_id], references: [id])

  @@unique([entity_community_id, profile_id])
  @@index([entity_community_id])
  @@index([profile_id])
}

model EntityCommunityMemberPosition {
  id          String                  @id() @default(uuid())
  member_id   String
  member      EntityCommunityMember   @relation(fields: [member_id], references: [id], onDelete: Cascade)
  position_id String
  position    EntityCommunityPosition @relation(fields: [position_id], references: [id], onDelete: Cascade)
  assignedAt  DateTime                @default(now())
  expiresAt   DateTime?

  @@unique([member_id, position_id])
  @@index([member_id])
  @@index([position_id])
}

model EntityCommunityPosition {
  id                               String                          @id() @default(uuid())
  name                             String
  entity_community_id              String
  entity_community                 EntityCommunity                 @relation(fields: [entity_community_id], references: [id], onDelete: Cascade)
  entity_community_member_position EntityCommunityMemberPosition[]
  requiredLevel                    Int                             @default(1)
  hierarchy_level                  Int                             @default(1)
  min_reputation                   Int                             @default(0)
  governance_weight                Int                             @default(0)
  requiresApproval                 Boolean                         @default(false)
  isStaffPosition                  Boolean                         @default(false)
  created_at                       DateTime                        @default(now())
  updated_at                       DateTime                        @updatedAt()

  @@unique([entity_community_id, name])
  @@index([entity_community_id])
}

/// One operational affiliation row per Profile per anchor EntityPosition (same rule as legacy EntityMember).
model ProfileOperationalAffiliation {
  id                        String                                  @id() @default(uuid())
  dominant_operational_kind OperationalRelationshipKind             @default(OPERATIONAL_STAFF)
  profile_id                String
  profile                   Profile                                 @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  entity_id                 String
  entity                    Entity                                  @relation(fields: [entity_id], references: [id], onDelete: Cascade)
  anchor_entity_position_id String
  anchor_entity_position    EntityPosition                          @relation("OperationalAffiliationAnchor", fields: [anchor_entity_position_id], references: [id], onDelete: Cascade)
  position_assignments      ProfileOperationalAffiliationPosition[]
  reputation_score          Int                                     @default(0)
  isVerified                Boolean                                 @default(false)
  expiresAt                 DateTime?
  posts                     Post[]

  @@unique([profile_id, anchor_entity_position_id])
  @@index([profile_id])
  @@index([entity_id])
  @@index([entity_id, dominant_operational_kind])
}

model ProfileOperationalAffiliationPosition {
  id                         String                        @id() @default(uuid())
  operational_affiliation_id String
  operational_affiliation    ProfileOperationalAffiliation @relation(fields: [operational_affiliation_id], references: [id], onDelete: Cascade)
  entity_position_id         String
  entity_position            EntityPosition                @relation(fields: [entity_position_id], references: [id], onDelete: Cascade)
  assignedAt                 DateTime                      @default(now())
  expiresAt                  DateTime?

  @@unique([operational_affiliation_id, entity_position_id])
  @@index([operational_affiliation_id])
}

model ProfileCommercialAffiliation {
  id                        String                                 @id() @default(uuid())
  commercial_kind           CommercialRelationshipKind
  profile_id                String
  profile                   Profile                                @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  entity_id                 String
  entity                    Entity                                 @relation(fields: [entity_id], references: [id], onDelete: Cascade)
  anchor_entity_position_id String
  anchor_entity_position    EntityPosition                         @relation("CommercialAffiliationAnchor", fields: [anchor_entity_position_id], references: [id], onDelete: Cascade)
  position_assignments      ProfileCommercialAffiliationPosition[]
  membership_tier           String?
  subscription_id           String?
  reputation_score          Int                                    @default(0)
  isVerified                Boolean                                @default(false)
  expiresAt                 DateTime?

  @@unique([profile_id, anchor_entity_position_id])
  @@index([profile_id])
  @@index([entity_id])
  @@index([entity_id, commercial_kind])
}

model ProfileCommercialAffiliationPosition {
  id                        String                       @id() @default(uuid())
  commercial_affiliation_id String
  commercial_affiliation    ProfileCommercialAffiliation @relation(fields: [commercial_affiliation_id], references: [id], onDelete: Cascade)
  entity_position_id        String
  entity_position           EntityPosition               @relation(fields: [entity_position_id], references: [id], onDelete: Cascade)
  assignedAt                DateTime                     @default(now())
  expiresAt                 DateTime?

  @@unique([commercial_affiliation_id, entity_position_id])
  @@index([commercial_affiliation_id])
}

model ProfileStrategicAffiliation {
  id                        String                                @id() @default(uuid())
  strategic_kind            StrategicRelationshipKind             @default(OTHER)
  profile_id                String
  profile                   Profile                               @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  entity_id                 String
  entity                    Entity                                @relation(fields: [entity_id], references: [id], onDelete: Cascade)
  anchor_entity_position_id String
  anchor_entity_position    EntityPosition                        @relation("StrategicAffiliationAnchor", fields: [anchor_entity_position_id], references: [id], onDelete: Cascade)
  position_assignments      ProfileStrategicAffiliationPosition[]
  reputation_score          Int                                   @default(0)
  isVerified                Boolean                               @default(false)
  expiresAt                 DateTime?

  @@unique([profile_id, anchor_entity_position_id])
  @@index([profile_id])
  @@index([entity_id])
  @@index([entity_id, strategic_kind])
}

model ProfileStrategicAffiliationPosition {
  id                       String                      @id() @default(uuid())
  strategic_affiliation_id String
  strategic_affiliation    ProfileStrategicAffiliation @relation(fields: [strategic_affiliation_id], references: [id], onDelete: Cascade)
  entity_position_id       String
  entity_position          EntityPosition              @relation(fields: [entity_position_id], references: [id], onDelete: Cascade)
  assignedAt               DateTime                    @default(now())
  expiresAt                DateTime?

  @@unique([strategic_affiliation_id, entity_position_id])
  @@index([strategic_affiliation_id])
}

model EntityPosition {
  id                             String                                  @id() @default(uuid())
  title                          String
  entity_id                      String
  entity                         Entity                                  @relation(fields: [entity_id], references: [id], onDelete: Cascade)
  operational_affiliation_anchor ProfileOperationalAffiliation[]         @relation("OperationalAffiliationAnchor")
  operational_assignment_rows    ProfileOperationalAffiliationPosition[]
  commercial_affiliation_anchors ProfileCommercialAffiliation[]          @relation("CommercialAffiliationAnchor")
  commercial_assignment_rows     ProfileCommercialAffiliationPosition[]
  strategic_affiliation_anchors  ProfileStrategicAffiliation[]           @relation("StrategicAffiliationAnchor")
  strategic_assignment_rows      ProfileStrategicAffiliationPosition[]
  created_at                     DateTime                                @default(now())
  updated_at                     DateTime                                @updatedAt()

  @@unique([entity_id, title])
  @@index([entity_id])
}

model Permission {
  id               String          @id() @default(uuid())
  value            String
  permission_scope PermissionScope
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt()
}

model RequestClaim {
  id                String              @id() @default(uuid())
  entity_id         String
  entity            Entity              @relation(fields: [entity_id], references: [id], onDelete: Cascade)
  community_id      String
  community         EntityCommunity     @relation(fields: [community_id], references: [id], onDelete: Cascade)
  user_id           String
  user              User                @relation(fields: [user_id], references: [id])
  claim_status      RequestClaimStatus  @default(PENDING)
  created_at        DateTime            @default(now())
  entity_email      String
  entity_phone      String
  instagram_url     String?
  additional_notes  String?
  entity_type       EntityType
  verification_type VerificationType
  claim_media       RequestClaimMedia[]

  @@unique([user_id, community_id, entity_id])
  @@index([user_id])
}

model RequestClaimMedia {
  id         String       @id() @default(uuid())
  claim_id   String
  claim      RequestClaim @relation(fields: [claim_id], references: [id], onDelete: Cascade)
  key        String
  type       MediaType
  created_at DateTime     @default(now())

  @@index([claim_id])
}

model PartnershipInvitation {
  id                       String                      @id() @default(uuid())
  inviter_entity_id        String
  inviter_entity           Entity                      @relation("InviterEntityInvitations", fields: [inviter_entity_id], references: [id], onDelete: Cascade)
  invitee_entity_id        String?
  invitee_entity           Entity?                     @relation("InviteeEntityInvitations", fields: [invitee_entity_id], references: [id])
  invitee_name             String?
  invitee_email            String?
  invitee_phone            String?
  invitee_instagram_handle String
  note                     String?
  status                   PartnershipInvitationStatus @default(PENDING)
  source                   PartnershipInvitationSource
  intent                   PartnershipInvitationIntent @default(ONBOARD_BUSINESS)
  reward_months            Int                         @default(0)
  accepted_at              DateTime?
  expires_at               DateTime?
  metadata                 Json?
  created_at               DateTime                    @default(now())
  updated_at               DateTime                    @updatedAt()
  partnership              Partnership?                @relation("InvitationPartnership")

  @@index([inviter_entity_id])
  @@index([invitee_entity_id])
  @@index([invitee_instagram_handle])
  @@index([invitee_email])
}

model Partnership {
  id                   String                 @id() @default(uuid())
  entity_a_id          String
  entity_a             Entity                 @relation("PartnershipEntityA", fields: [entity_a_id], references: [id], onDelete: Cascade)
  entity_b_id          String
  entity_b             Entity                 @relation("PartnershipEntityB", fields: [entity_b_id], references: [id], onDelete: Cascade)
  status               PartnershipStatus      @default(ACTIVE)
  details              Json?
  partnershipType      PartnershipType?
  origin_invitation_id String?
  origin_invitation    PartnershipInvitation? @relation("InvitationPartnership", fields: [origin_invitation_id], references: [id])
  created_at           DateTime               @default(now())
  updated_at           DateTime               @updatedAt()

  @@unique([entity_a_id, entity_b_id])
  @@unique([origin_invitation_id])
  @@index([origin_invitation_id])
}

model UserCommunityVisit {
  id                  String          @id() @default(uuid())
  visited_at          DateTime        @default(now())
  source              VisitSource     @default(DIRECT_QR)
  profile_id          String
  profile             Profile         @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  entity_community_id String
  entity_community    EntityCommunity @relation(fields: [entity_community_id], references: [id], onDelete: Cascade)
  feel_id             String?
  feel                ReferenceFeels? @relation(fields: [feel_id], references: [id])
  vibe_id             String?
  vibe                ReferenceVibes? @relation(fields: [vibe_id], references: [id])

  @@index([profile_id])
  @@index([entity_community_id])
  @@index([feel_id])
  @@index([vibe_id])
  @@index([visited_at])
}

model ReferencePersonas {
  id                  String            @id() @default(uuid())
  icon_url            String?
  persona_name        String            @unique()
  persona_description String
  profile_personas    ProfilePersonas[]
}

model ReferenceValues {
  id                String          @id() @default(uuid())
  value_name        String          @unique()
  value_description String
  profile_values    ProfileValues[]
}

model ReferenceInterests {
  id                String             @id() @default(uuid())
  interest_name     String             @unique()
  interest_category String
  profile_interests ProfileInterests[]
}

model ReferenceEntityArchetypes {
  id                    String                    @id() @default(uuid())
  icon_url              String?
  archetype_name        String                    @unique()
  archetype_description String
  entities              EntityArchetypesEntries[]
}

model ReferenceEntityValues {
  id                String                @id() @default(uuid())
  value_name        String                @unique()
  value_description String
  entities          EntityValuesEntries[]
}

model ReferenceEntityInterests {
  id                String                   @id() @default(uuid())
  interest_name     String                   @unique()
  interest_category String
  entities          EntityInterestsEntries[]
}

model ReferenceBusinessTypes {
  id                   String @id() @default(uuid())
  industry             String
  industry_description String
  business_type        String @default("OTHER")

  @@unique([industry, business_type])
}

model ReferenceVibes {
  id          String               @id() @default(uuid())
  name        String               @unique()
  description String?
  category    String?
  visits      UserCommunityVisit[]

  @@index([name])
}

model ReferenceFeels {
  id          String               @id() @default(uuid())
  name        String               @unique()
  emoji       String?
  description String?
  visits      UserCommunityVisit[]
}

model Enterprise {
  id         String   @id() @default(uuid())
  name       String
  created_at DateTime @default(now())
  posts      Post[]
  entities   Entity[]
}

model Poll {
  id           String          @id() @default(uuid())
  community_id String
  community    EntityCommunity @relation(fields: [community_id], references: [id], onDelete: Cascade)
  profile_id   String
  profile      Profile         @relation("PollCreator", fields: [profile_id], references: [id])
  poll_title   String
  description  String
  created_at   DateTime        @default(now())
  poll_options PollOption[]
}

model PollOption {
  id         String     @id() @default(uuid())
  poll_id    String
  poll       Poll       @relation(fields: [poll_id], references: [id], onDelete: Cascade)
  content    String
  vote_count Int
  votes      PollVote[]

  @@index([poll_id])
}

model PollVote {
  id          String     @id() @default(uuid())
  profile_id  String
  option_id   String
  voted_at    DateTime   @default(now())
  poll_option PollOption @relation(fields: [option_id], references: [id], onDelete: Cascade)
  profile     Profile    @relation("PollVotesByProfile", fields: [profile_id], references: [id])

  @@unique([profile_id, option_id])
  @@index([profile_id])
}

model Brand {
  id        String   @id() @default(cuid())
  entity_id String   @unique()
  entity    Entity   @relation(fields: [entity_id], references: [id])
  colors    Json?
  qrStyle   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt()
}
