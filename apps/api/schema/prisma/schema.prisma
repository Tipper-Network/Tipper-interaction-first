  user_invite_tokens       UserInviteToken?
  root_invites             UserInvite[]             @relation("RootInviter")
  received_invites         UserInvite[]             @relation("InvitedUser")
}

model Profile {
  id                           String                          @id() @default(uuid())
  first_name                   String                          @default("")
  last_name                    String                          @default("")
  bio                          String                          @default("")
  avatar_url                   String                          @default("")
  location                     String                          @default("")
  date_of_birth                DateTime?
  interests_setup              Boolean                         @default(false)
  profile_setup                Boolean                         @default(false)
  personas_setup               Boolean                         @default(false)
  values_setup                 Boolean                         @default(false)
  reputation                   Int                             @default(0)
  user_level                   Int                             @default(0)
  user_id                      String                          @unique()
  user                         User                            @relation(fields: [user_id], references: [id])
  profile_personas             ProfilePersonas[]
  profile_interests            ProfileInterests[]
  profile_values               ProfileValues[]
  entity_community_memberships EntityCommunityMember[]
  operational_affiliations     ProfileOperationalAffiliation[]
  commercial_affiliations      ProfileCommercialAffiliation[]
  strategic_affiliations       ProfileStrategicAffiliation[]
  community_visits             UserCommunityVisit[]
  initiated_communities        EntityCommunity[]               @relation("CommunityInitiator")
  votes                        Vote[]
  poll_votes                   PollVote[]                      @relation("PollVotesByProfile")
  polls_created                Poll[]                          @relation("PollCreator")
  post_comments                PostComments[]                  @relation("PostCommentAuthor")
  group_chat_memberships       GroupChatMembers[]              @relation("GroupChatMembership")
  group_chat_messages          GroupChatMessages[]             @relation("GroupChatMessageAuthor")
  thoughts                     Thought[]                       @relation("ThoughtAuthor")
  thought_comments             ThoughtComment[]                @relation("ThoughtCommentAuthor")
  community_qnas               CommunityQNA[]                  @relation("CommunityQuestionAuthor")
  community_qna_responses      CommunityQNAResponses[]         @relation("CommunityQNAReplyAuthor")
  feedback_tickets             FeedbackTicket[]                @relation("FeedbackTicketAuthor")
  feedback_comments            FeedbackComment[]               @relation("FeedbackCommentAuthor")
  feedback_status_changes      FeedbackTicketStatusHistory[]   @relation("TicketStatusChanger")
  suggested_tags_created       Tag[]                           @relation("ProfileSuggestedTags")

  @@index([user_id])
}

model ProfilePersonas {
  id         String            @id() @default(uuid())
  profile_id String
  persona_id String
  profile    Profile           @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  persona    ReferencePersonas @relation(fields: [persona_id], references: [id], onDelete: Cascade)

  @@unique([profile_id, persona_id])
  @@index([profile_id])
}

model ProfileInterests {
  id          String             @id() @default(uuid())
  profile_id  String
  interest_id String
  profile     Profile            @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  interests   ReferenceInterests @relation(fields: [interest_id], references: [id], onDelete: Cascade)

  @@unique([profile_id, interest_id])
  @@index([profile_id])
}

model ProfileValues {
  id         String          @id() @default(uuid())
  profile_id String
  value_id   String
  profile    Profile         @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  value      ReferenceValues @relation(fields: [value_id], references: [id], onDelete: Cascade)

  @@unique([profile_id, value_id])
  @@index([profile_id])
}

model EmailVerificationToken {
  id        String   @id() @default(uuid())
  email     String
  token     String
  expiresAt DateTime
  user      User     @relation(fields: [email], references: [email], onDelete: Cascade)

  @@unique([email, token])
  @@index([email])
  @@index([expiresAt])
}

model Post {
  id                                 String                        @id() @default(uuid())
  description                        String
  type                               PostType
  visibility                         PostTarget                    @default(ALL)
  status                             PostStatus                    @default(PUBLISHED)
  created_at                         DateTime                      @default(now())
  expires_at                         DateTime?
  comments_count                     Int                           @default(0)
  /////////// Enterprise Decisions ///////////
  boosted_until                      DateTime?
  pinned_until                       DateTime?
  comments                           PostComments[]
  media                              PostMedia[]
  entity_id                          String
  entity                             Entity                        @relation(fields: [entity_id], references: [id])
  profile_operational_affiliation_id String
  profile_operational_affiliation    ProfileOperationalAffiliation @relation(fields: [profile_operational_affiliation_id], references: [id])
  vote_box_id                        String                        @unique()
  vote_box                           VoteBox?                      @relation(fields: [vote_box_id], references: [id])
  published_by_enterprise_id         String?
  published_by_enterprise            Enterprise?                   @relation(fields: [published_by_enterprise_id], references: [id])

  @@index([entity_id])
  @@index([profile_operational_affiliation_id])
  @@index([published_by_enterprise_id])
}

model PostMedia {
  id         String    @id() @default(uuid())
  post_id    String
  post       Post      @relation(fields: [post_id], references: [id], onDelete: Cascade)
  key        String
  type       MediaType
  created_at DateTime  @default(now())

  @@index([post_id])
}

model PostComments {
  id          String   @id() @default(uuid())
  post_id     String
  post        Post     @relation(fields: [post_id], references: [id], onDelete: Cascade)
  profile_id  String
  profile     Profile  @relation("PostCommentAuthor", fields: [profile_id], references: [id])
  content     String
  created_at  DateTime @default(now())
  vote_box_id String?
  vote_box    VoteBox? @relation(fields: [vote_box_id], references: [id])

  @@unique([vote_box_id])
  @@index([post_id, profile_id])
  @@index([profile_id])
}

model VoteBox {
  id                      String                 @id() @default(uuid())
  upvotes_count           Int                    @default(0)
  downvotes_count         Int                    @default(0)
  helpful_count           Int                    @default(0)
  not_helpful_count       Int                    @default(0)
  neutral_count           Int                    @default(0)
  created_at              DateTime               @default(now())
  updated_at              DateTime               @updatedAt()
  votes                   Vote[]
  post                    Post?
  post_comment            PostComments?
  community_qna           CommunityQNA?
  community_qna_response  CommunityQNAResponses?
  group_chat              GroupChat?
  group_chat_message      GroupChatMessages?
  tag                     Tag?
  thought                 Thought?
  thought_media           ThoughtMedia?
  thought_comment         ThoughtComment?
  feedback_ticket         FeedbackTicket?
  feedback_comment        FeedbackComment?
  entity_community_invite EntityCommunityInvite?
}

model Vote {
  id          String   @id() @default(uuid())
  vote_type   VoteType
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt()
  profile_id  String
  profile     Profile  @relation(fields: [profile_id], references: [id])
  vote_box_id String
  vote_box    VoteBox  @relation(fields: [vote_box_id], references: [id], onDelete: Cascade)

  @@unique([profile_id, vote_box_id])
  @@index([vote_box_id, profile_id])
  @@index([profile_id])
}

model CommunityQNA {
  id                      String                  @id() @default(uuid())
  question                String
  tags                    String[]                @default([""])
  created_at              DateTime                @default(now())
  updated_at              DateTime                @updatedAt()
  responses_count         Int                     @default(0)
  profile_id              String
  profile                 Profile                 @relation("CommunityQuestionAuthor", fields: [profile_id], references: [id])
  community_qna_responses CommunityQNAResponses[]
  vote_box_id             String?
  vote_box                VoteBox?                @relation(fields: [vote_box_id], references: [id])
  community_id            String
  community               EntityCommunity         @relation(fields: [community_id], references: [id])

  @@unique([vote_box_id])
  @@index([community_id, profile_id])
}

model CommunityQNAResponses {
  id                 String                  @id() @default(uuid())
  community_qna_id   String
  community_qna      CommunityQNA            @relation(fields: [community_qna_id], references: [id])
  parent_response_id String?
  parent_response    CommunityQNAResponses?  @relation("CommunityQNAResponseHierarchy", fields: [parent_response_id], references: [id], onDelete: Cascade)
  child_responses    CommunityQNAResponses[] @relation("CommunityQNAResponseHierarchy")
  depth              Int                     @default(0)
  response           String
  created_at         DateTime                @default(now())
  updated_at         DateTime                @updatedAt()
  profile_id         String
  profile            Profile                 @relation("CommunityQNAReplyAuthor", fields: [profile_id], references: [id])
  vote_box_id        String?
  vote_box           VoteBox?                @relation(fields: [vote_box_id], references: [id])

  @@unique([vote_box_id])
  @@index([community_qna_id, parent_response_id])
}

model GroupChat {
  id             String              @id() @default(uuid())
  community_id   String
  community      EntityCommunity     @relation(fields: [community_id], references: [id])
  groupchat_name String
  members_count  Int                 @default(0)
  created_at     DateTime            @default(now())
  members        GroupChatMembers[]
  messages       GroupChatMessages[]
  vote_box_id    String?
  vote_box       VoteBox?            @relation(fields: [vote_box_id], references: [id])

  @@unique([vote_box_id])
  @@index([community_id])
}

model GroupChatMembers {
  id            String    @id() @default(uuid())
  group_chat_id String
  group_chat    GroupChat @relation(fields: [group_chat_id], references: [id], onDelete: Cascade)
  profile_id    String
  profile       Profile   @relation("GroupChatMembership", fields: [profile_id], references: [id])
  joined_at     DateTime  @default(now())

  @@unique([group_chat_id, profile_id])
  @@index([group_chat_id])
}

model GroupChatMessages {
  id            String    @id() @default(uuid())
  group_chat_id String
  group_chat    GroupChat @relation(fields: [group_chat_id], references: [id], onDelete: Cascade)
  profile_id    String
  profile       Profile   @relation("GroupChatMessageAuthor", fields: [profile_id], references: [id])
  user_name     String    @default("unknown")
  content       String
  sent_at       DateTime  @default(now())
  vote_box_id   String?
  vote_box      VoteBox?  @relation(fields: [vote_box_id], references: [id])

  @@unique([vote_box_id])
  @@index([profile_id, group_chat_id])
  @@index([group_chat_id])
}

model Tag {
  id                    String        @id() @default(uuid())
  slug                  String        @unique()
  label                 String
  type                  TagType
  status                TagStatus
  tagEntity             EntityTag[]
  tagOffering           OfferingTag[]
  tagThought            ThoughtTag[]
  vote_box_id           String?       @unique()
  vote_box              VoteBox?      @relation(fields: [vote_box_id], references: [id])
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt()
  created_by_profile_id String?
  created_by_profile    Profile?      @relation("ProfileSuggestedTags", fields: [created_by_profile_id], references: [id])
}

model EntityTag {
  id        String   @id() @default(cuid())
  entity_id String
  entity    Entity   @relation(fields: [entity_id], references: [id])
  tag_id    String
  tag       Tag      @relation(fields: [tag_id], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt()

  @@index([tag_id, entity_id])
}

model OfferingTag {
  id          String   @id() @default(uuid())
  tag_id      String
  tag         Tag      @relation(fields: [tag_id], references: [id], onDelete: Cascade)
  offering_id String
