model ThoughtMedia {
  id          String    @id() @default(uuid())
  thought_id  String
  thought     Thought   @relation(fields: [thought_id], references: [id], onDelete: Cascade)
  key         String
  type        MediaType
  created_at  DateTime  @default(now())
  vote_box_id String?
  vote_box    VoteBox?  @relation(fields: [vote_box_id], references: [id])

  @@unique([vote_box_id])
  @@index([thought_id])
}

model ThoughtComment {
  id          String   @id() @default(uuid())
  thought_id  String
  thought     Thought  @relation(fields: [thought_id], references: [id], onDelete: Cascade)
  profile_id  String
  profile     Profile  @relation("ThoughtCommentAuthor", fields: [profile_id], references: [id])
  content     String
  created_at  DateTime @default(now())
  vote_box_id String?
  vote_box    VoteBox? @relation(fields: [vote_box_id], references: [id])

  @@unique([vote_box_id])
  @@index([thought_id, profile_id])
  @@index([profile_id])
