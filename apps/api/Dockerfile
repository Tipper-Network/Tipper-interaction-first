# syntax=docker/dockerfile:1
FROM node:22-alpine AS base
RUN apk update && apk upgrade --no-cache \
    && corepack enable && corepack prepare pnpm@9.12.0 --activate

# ─── deps stage ───────────────────────────────────────────────────────────────
FROM base AS deps
WORKDIR /app

COPY pnpm-workspace.yaml pnpm-lock.yaml package.json .npmrc ./
COPY packages/shared/package.json ./packages/shared/package.json
COPY apps/api/package.json ./apps/api/package.json
# Stub web manifest so pnpm treats the workspace as complete
COPY apps/web/package.json ./apps/web/package.json

# Only install api + its workspace deps (skips web's heavy deps like next, react, etc.)
RUN --mount=type=cache,id=pnpm,target=/root/.local/share/pnpm/store \
    pnpm install --frozen-lockfile --filter @tipper/api...

# ─── build stage ──────────────────────────────────────────────────────────────
FROM base AS builder
WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/packages/shared/node_modules ./packages/shared/node_modules
COPY --from=deps /app/apps/api/node_modules ./apps/api/node_modules

COPY pnpm-workspace.yaml pnpm-lock.yaml package.json .npmrc ./
COPY packages/shared ./packages/shared
COPY apps/api ./apps/api

# schema/prisma/schema.prisma is committed (generated by zenstack locally).
# api's `build` script runs `prisma generate` then `nest build`.
# `--filter @tipper/api...` topo-builds @tipper/shared first.
RUN pnpm --filter @tipper/api... run build

# Drop dev-only deps from node_modules to slim the runner.
RUN pnpm --filter @tipper/api... --prod deploy /app/deploy

# ─── production stage ─────────────────────────────────────────────────────────
# node:22-alpine has a shell — required for Dokploy pre-deploy commands
# (e.g., `prisma migrate deploy`).
FROM node:22-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production \
    PORT=3001

RUN addgroup --system --gid 1001 nodejs \
    && adduser --system --uid 1001 nestjs

# `pnpm deploy` produced a fully self-contained dir at /app/deploy with
# only production deps and built shared package included.
COPY --from=builder --chown=nestjs:nodejs /app/deploy ./
# dist of the built api app
COPY --from=builder --chown=nestjs:nodejs /app/apps/api/dist ./dist
# Schema dir needed for `prisma migrate deploy` (Dokploy pre-deploy command)
COPY --from=builder --chown=nestjs:nodejs /app/apps/api/schema ./schema
# prisma.config.ts is read by the prisma CLI when migrate deploy runs
COPY --from=builder --chown=nestjs:nodejs /app/apps/api/prisma.config.ts ./prisma.config.ts

USER nestjs
EXPOSE 3001

CMD ["node", "dist/main"]
