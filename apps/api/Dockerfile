# syntax=docker/dockerfile:1
FROM node:22-alpine AS base
RUN apk update && apk upgrade --no-cache \
    && corepack enable && corepack prepare pnpm@9.12.0 --activate

# ─── deps stage ───────────────────────────────────────────────────────────────
FROM base AS deps
WORKDIR /app

# Copy workspace manifests only (layer cache)
COPY pnpm-workspace.yaml package.json .npmrc ./
COPY packages/shared/package.json ./packages/shared/package.json
COPY apps/api/package.json ./apps/api/package.json
# Stub web so pnpm doesn't complain about missing workspace member
COPY apps/web/package.json ./apps/web/package.json

RUN pnpm install --frozen-lockfile

# ─── build stage ──────────────────────────────────────────────────────────────
FROM base AS builder
WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/packages/shared/node_modules ./packages/shared/node_modules
COPY --from=deps /app/apps/api/node_modules ./apps/api/node_modules

COPY pnpm-workspace.yaml package.json .npmrc ./
COPY packages/shared ./packages/shared
COPY apps/api ./apps/api

# schema/prisma/schema.prisma is committed (generated by zenstack locally).
# `pnpm --filter @tipper/api... build` topo-builds @tipper/shared first, then runs
# api's `build` script which itself runs `prisma generate` before `nest build`.
RUN pnpm --filter @tipper/api... run build

# ─── production stage ─────────────────────────────────────────────────────────
# Chainguard node: zero-CVE guarantee, updated daily, non-root by default
FROM cgr.dev/chainguard/node:latest AS runner
WORKDIR /app

ENV NODE_ENV=production

COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/packages/shared/dist ./packages/shared/dist
COPY --from=builder /app/packages/shared/package.json ./packages/shared/package.json
COPY --from=builder /app/apps/api/dist ./apps/api/dist
COPY --from=builder /app/apps/api/package.json ./apps/api/package.json
COPY --from=builder /app/apps/api/node_modules ./apps/api/node_modules
# schema dir needed in runner for prisma migrate deploy (Dokploy pre-deploy command)
COPY --from=builder /app/apps/api/schema ./apps/api/schema

WORKDIR /app/apps/api
EXPOSE 3001

CMD ["dist/main"]
