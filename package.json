{
  "name": "tipper",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm -r --parallel --if-present run dev",
    "build": "pnpm -r run build",
    "build:api": "pnpm --filter @tipper/api... run build",
    "build:web": "pnpm --filter @tipper/web... run build",
    "format": "pnpm -r --parallel --if-present run format",
    "lint": "pnpm -r --parallel --if-present run lint",

    "db:generate": "pnpm --filter @tipper/api run prisma:generate",
    "db:migrate": "pnpm --filter @tipper/api run prisma:migrate:dev",
    "db:migrate:deploy": "pnpm --filter @tipper/api run prisma:migrate:deploy",
    "db:migrate:create": "pnpm --filter @tipper/api run prisma:migrate:create",
    "db:reset": "pnpm --filter @tipper/api run prisma:migrate:reset",
    "db:push": "pnpm --filter @tipper/api run prisma:db:push",
    "db:studio": "pnpm --filter @tipper/api run prisma:studio",
    "db:schema:generate": "pnpm --filter @tipper/api run zenstack:generate",
    "seed": "pnpm --filter @tipper/api run seed"
  }
}
